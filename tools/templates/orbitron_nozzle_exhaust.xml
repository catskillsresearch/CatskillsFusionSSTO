<?xml version="1.0"?>
<!-- Orbitron CD nozzle exhaust — rates/sizes driven by JSBSim orbitron_sfx + arcjet outputs. -->
<PropertyList>

  <!-- Hot core: emissive annulus, scales with nozzle_volume and thrust -->
  <particlesystem>
    <name>orbitron_nozzle_core</name>
    <texture>annulus.png</texture>
    <emissive>true</emissive>
    <lighting>false</lighting>
    <x-m>0.0</x-m>
    <y-m>0.0</y-m>
    <z-m>0.0</z-m>
    <pitch-deg>0.0</pitch-deg>
    <heading-deg>0.0</heading-deg>
    <condition>
      <greater-than>
        <property>/fdm/jsbsim/systems/orbitron_sfx/nozzle_volume</property>
        <value>0.02</value>
      </greater-than>
    </condition>
    <attach>local</attach>
    <placer>
      <type>point</type>
    </placer>
    <shooter>
      <theta-min-deg>-4</theta-min-deg>
      <theta-max-deg>4</theta-max-deg>
      <phi-min-deg>-2</phi-min-deg>
      <phi-max-deg>2</phi-max-deg>
      <speed-mps>
        <property>/fdm/jsbsim/systems/orbitron_vfx/nozzle_exhaust_speed-mps</property>
        <spread>12</spread>
      </speed-mps>
    </shooter>
    <counter>
      <particles-per-sec>
        <property>/fdm/jsbsim/systems/orbitron_vfx/nozzle_core_particle_rate</property>
        <spread>6</spread>
      </particles-per-sec>
    </counter>
    <align>billboard</align>
    <particle>
      <start>
        <color>
          <red><value>1.0</value></red>
          <green><value>0.92</value></green>
          <blue><value>0.55</value></blue>
          <alpha>
            <property>/fdm/jsbsim/systems/orbitron_sfx/nozzle_volume</property>
            <factor>0.95</factor>
            <offset>0.05</offset>
            <min>0.0</min>
            <max>1.0</max>
          </alpha>
        </color>
        <size>
          <property>/fdm/jsbsim/systems/orbitron_vfx/nozzle_core_size-m</property>
          <min>0.08</min>
          <max>1.4</max>
        </size>
      </start>
      <end>
        <color>
          <red><value>0.95</value></red>
          <green><value>0.45</value></green>
          <blue><value>0.08</value></blue>
          <alpha>
            <property>/fdm/jsbsim/systems/orbitron_sfx/nozzle_volume</property>
            <factor>0.35</factor>
            <min>0.0</min>
            <max>0.6</max>
          </alpha>
        </color>
        <size>
          <property>/fdm/jsbsim/systems/orbitron_vfx/nozzle_core_size-m</property>
          <factor>2.8</factor>
          <min>0.2</min>
          <max>3.5</max>
        </size>
      </end>
      <life-sec>
        <value>0.35</value>
        <spread>0.08</spread>
      </life-sec>
      <mass-kg>0.02</mass-kg>
      <radius-m>0.05</radius-m>
    </particle>
    <program>
      <fluid>air</fluid>
      <gravity type="bool">false</gravity>
      <wind type="bool">true</wind>
    </program>
  </particlesystem>

  <!-- Outer shear / smoke plume: mdot + nozzle_volume -->
  <particlesystem>
    <name>orbitron_nozzle_plume</name>
    <texture>smoke.png</texture>
    <emissive>false</emissive>
    <lighting>false</lighting>
    <x-m>0.15</x-m>
    <y-m>0.0</y-m>
    <z-m>0.0</z-m>
    <pitch-deg>0.0</pitch-deg>
    <heading-deg>0.0</heading-deg>
    <condition>
      <greater-than>
        <property>/fdm/jsbsim/systems/orbitron_sfx/nozzle_volume</property>
        <value>0.04</value>
      </greater-than>
    </condition>
    <attach>local</attach>
    <placer>
      <type>point</type>
    </placer>
    <shooter>
      <theta-min-deg>-8</theta-min-deg>
      <theta-max-deg>8</theta-max-deg>
      <phi-min-deg>-5</phi-min-deg>
      <phi-max-deg>5</phi-max-deg>
      <speed-mps>
        <property>/fdm/jsbsim/systems/orbitron_vfx/nozzle_exhaust_speed-mps</property>
        <factor>0.72</factor>
        <spread>18</spread>
      </speed-mps>
    </shooter>
    <counter>
      <particles-per-sec>
        <property>/fdm/jsbsim/systems/orbitron_vfx/nozzle_plume_particle_rate</property>
        <spread>12</spread>
      </particles-per-sec>
    </counter>
    <align>billboard</align>
    <particle>
      <start>
        <color>
          <red><value>0.75</value></red>
          <green><value>0.78</value></green>
          <blue><value>0.82</value></blue>
          <alpha>
            <property>/fdm/jsbsim/systems/orbitron_sfx/nozzle_volume</property>
            <factor>0.55</factor>
            <offset>0.08</offset>
            <min>0.0</min>
            <max>0.85</max>
          </alpha>
        </color>
        <size>
          <property>/fdm/jsbsim/systems/orbitron_vfx/nozzle_plume_size-m</property>
          <min>0.15</min>
          <max>2.2</max>
        </size>
      </start>
      <end>
        <color>
          <red><value>0.55</value></red>
          <green><value>0.55</value></green>
          <blue><value>0.58</value></blue>
          <alpha><value>0.05</value></alpha>
        </color>
        <size>
          <property>/fdm/jsbsim/systems/orbitron_vfx/nozzle_plume_size-m</property>
          <factor>3.2</factor>
          <min>0.4</min>
          <max>5.5</max>
        </size>
      </end>
      <life-sec>
        <value>1.1</value>
        <spread>0.25</spread>
      </life-sec>
      <mass-kg>0.05</mass-kg>
      <radius-m>0.08</radius-m>
    </particle>
    <program>
      <fluid>air</fluid>
      <gravity type="bool">true</gravity>
      <wind type="bool">true</wind>
    </program>
  </particlesystem>

</PropertyList>
