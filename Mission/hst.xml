<?xml version="1.0" ?>

<!-- Shuttle set up for a launch window to Hubble Space Telescope (HST) -->
<!--All Scenarios: OMS-2 TIG 000/00:48:00 thetaT 320 H 288 c1 0.0 c2 0.0 for PEG-4 insertion for a gamma MECO close to zero-->

<!--28.65° scenario: Start Lan 192.02°    Hubble Lan 189.47 (RTHU)  2mn before Launch // -->
<!-- Automatic Ignition On -->

<!-- Auto OMS 2-->
<!-- PEG 7 phasing solution mm 105 // TIG 46mn:30s // PEG7 Dvx 149 fts // 300 x 130 Nm Orbit targeted for initial phasing -->
<!-- PEG 4 Orbit circularisation solution mm 105 // TIG 48 mns // PEG4 HT=288Nm  Theta=320° // 290Nm ish Orbit -->

