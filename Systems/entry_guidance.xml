<switch name="systems/entry_guidance/drag-required">
	<default value="systems/entry_guidance/drag-entry-traj1"/>
	<test logic="AND" value="systems/entry_guidance/drag-entry-traj2">
		velocities/vtrue-fps LT 17000
		velocities/vtrue-fps GT 14000
	</test>
	<test logic="AND" value="systems/entry_guidance/drag-entry-traj3">
		velocities/vtrue-fps LT 14000
		velocities/vtrue-fps GT 10500
	</test>
	<test logic="AND" value="systems/entry_guidance/drag-entry-traj4">
		velocities/vtrue-fps LT 10500
		velocities/vtrue-fps GT 6000
	</test>
	<test value="systems/entry_guidance/drag-entry-traj5">
		velocities/vtrue-fps LT 6000
	</test>
</switch>

<!-- Guidance box range factor based on drag error = 1 + (Da - Dr)/(Da + Dr)-->
<fcs_function name="systems/entry_guidance/drag-guidance-box">
		<function>
			<sum>
			<value>1.0</value>
			<quotient>
				<difference>
					<property>systems/entry_guidance/aero-drag-deceleration-fts</property>
					<property>systems/entry_guidance/drag-required</property>
				</difference>
				<sum>
					<property>systems/entry_guidance/aero-drag-deceleration-fts</property>
					<property>systems/entry_guidance/drag-required</property>
				</sum>
			</quotient>
			</sum>
		</function>		
</fcs_function>

<!-- Hdot correction when Drag is different than Drequired (based on Entry workbook Hdot bias 20 x (D - D req)) -->

<fcs_function name="systems/entry_guidance/drag-bias-factor">
		<function>
			<table>
        		<independentVar lookup="row">velocities/vtrue-fps</independentVar>
         		<tableData>
				 17000	0
				 19000	-10
				 21000	-20
				 25000	-20
         		</tableData>
      		</table>
		</function>
	</fcs_function>

	<fcs_function name="systems/entry_guidance/delta-drag-bias-func">
		<function>
			<product>
				 <!--property>systems/entry_guidance/drag-bias-factor</property-->
				<value>-20</value>
				<difference>
					<property>systems/entry_guidance/aero-drag-deceleration-fts</property>
					<property>systems/entry_guidance/nominal-dref</property>
				</difference>
			</product>
		</function>
	</fcs_function>

