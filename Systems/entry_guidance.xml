<?xml version="1.0"?>

<system>

	<channel name="Entry and TAEM guidance management">

		<switch name="systems/entry_guidance/entry-guidance-activation">
			<default value="0.0"/>
			<test logic="OR" value="1.0">
				systems/ap/auto-entry-active == 1
				systems/dps/ops == 6
			</test>
		</switch>

		<switch name="systems/entry_guidance/taem-guidance-activation">
			<default value="0.0"/>
			<test value="1.0">
				systems/ap/auto-taem-active == 1
			</test>
		</switch>

		<switch name="systems/entry_guidance/pfd-entry-cues-activation">
			<default value="0.0"/>
			<test logic="OR" value="1.0">
				systems/dps/major-mode == 304
				systems/dps/major-mode == 305
				systems/dps/major-mode == 602
				systems/dps/major-mode == 603
			</test>
		</switch>

	</channel>

	<channel name="Entry groundtrack guidance" execute="systems/entry_guidance/entry-guidance-activation">

	<switch name="systems/entry_guidance/guidance-active">
			<default value="0.0"/>
			<test logic="OR" value="1.0">
				systems/entry_guidance/guidance-mode == 1
				systems/entry_guidance/guidance-mode == 2
				systems/entry_guidance/guidance-mode == 3
			</test>
	</switch>

	
	<fcs_function name="systems/entry_guidance/aero-deceleration-g">
		<function>
		<quotient>
			<pow>
				<sum>
				<pow>
					<property>forces/fbx-aero-lbs</property>
					<value>2.0</value>				
				</pow>
				<pow>
					<property>forces/fby-aero-lbs</property>
					<value>2.0</value>				
				</pow>
				<pow>
					<property>forces/fbz-aero-lbs</property>
					<value>2.0</value>				
				</pow>
				</sum>
				<value>0.5</value>
			</pow>			
			<property>inertia/weight-lbs</property>
		</quotient>
		</function>		
	</fcs_function>

<!-- Actual Drag -->

	<fcs_function name="systems/entry_guidance/aero-drag-deceleration-fts">
		<function>
			<product>
				<value>32.2</value>
				<quotient>
					<property>forces/fwx-aero-lbs</property>
					<property>inertia/weight-lbs</property>
				</quotient>
			</product>
		</function>		
	</fcs_function>


<!-- Equilibrium Drag -->

	<fcs_function name="systems/entry_guidance/aero-drag-equilibrium-fts">
		<function>
			<quotient>
				<product>
					<value>32.2</value>
					<difference>
						<value>1.0</value>
						<quotient>
							<pow>
								<property>velocities/eci-velocity-mag-fps</property>
								<value>2.0</value>				
							</pow>
							<pow>
								<value>26000</value>
								<value>2.0</value>				
							</pow>
						</quotient>
					</difference>
				</product>
				<product>
					<quotient>
						<property>aero/coefficient/CL-basic</property>
						<property>aero/coefficient/CD-basic</property>
					</quotient>
					<cos>
						<product>
							<value>0.01745</value>
							<property>systems/ap/entry/roll-abs-deg</property>
						</product>
					</cos>
				</product>
			</quotient>
		</function>		
	</fcs_function>

