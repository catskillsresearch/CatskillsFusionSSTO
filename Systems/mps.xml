<?xml version="1.0"?>

<!-- Main Propulsion System hardware simulation for the Space Shuttle -->
<!-- Thorsten Renk 2015 -->

<!-- Internal JSB engine numbering differs from NASA numbering for historical reasons -->
<!-- NASA engine 1: center engine    JSBSim SSME-1, engine[0]: left engine -->
<!-- NASA engine 2: left engine      JSBSim SSME-2, engine[1]: right engine -->
<!-- NASA engine 3: right engine     JSBSim SSME-3, engine[2]: center engine -->

<system>

	<channel name="MPS management and flags">
		<!-- set engines non-operational if there's no propellant -->
		<!-- JSBSim makes them stop working anyway, but displays need the flag -->

		<switch name="systems/propellant/propellant-available">
			<default value="1.0"/>
			<test value="0.0">
				propulsion/tank[0]/contents-lbs LT 1000.0
			</test>
		</switch>

		<fcs_function name="systems/mps/helium/et-fuel-fraction">
		<function>
			<min>
			<quotient>
				<property>propulsion/tank[0]/contents-lbs</property>
				<value>228571.5</value>
			</quotient>
			<value>0.999</value>
			</min>
		</function>
		</fcs_function>

		<switch name="systems/mps/engine/engine-running">
			<default value="0.0"/>
			<test value="1.0">
				systems/mps/engine/engine-operational == 1
				/sim/config/shuttle/prelaunch-flag == 0
			</test>
		</switch>

		<switch name="systems/mps/engine[1]/engine-running">
			<default value="0.0"/>
			<test value="1.0">
				systems/mps/engine[1]/engine-operational == 1
				/sim/config/shuttle/prelaunch-flag == 0
			</test>
		</switch>

		<switch name="systems/mps/engine[2]/engine-running">
			<default value="0.0"/>
			<test value="1.0">
				systems/mps/engine[2]/engine-operational == 1
				/sim/config/shuttle/prelaunch-flag == 0
			</test>
		</switch>

		<switch name="systems/mps/mps-running">
			<default value="0.0"/>
			<test logic="OR" value="1.0">
				systems/mps/engine/engine-running == 1
				systems/mps/engine[1]/engine-running == 1
				systems/mps/engine[2]/engine-running == 1
			</test>
		</switch>





	</channel>



	<channel name="Main propulsion system helium flow">

		<!-- the helium system provides emergency power for valves and shutdown -->
		<!-- does the purge of the engines -->
		<!-- and is used for the propellant dump -->

		<!-- translate 3-way switch positions into valve positions -->

		<switch name="systems/mps/helium[0]/interconnect-in-valve-status">
			<default value="0.0"/>
			<test logic="AND" value="1.0">
				systems/mps/engine[0]/helium-interconnect-valve-status == 1
			</test>
		</switch>

		<switch name="systems/mps/helium[1]/interconnect-in-valve-status">
			<default value="0.0"/>
			<test logic="AND" value="1.0">
				systems/mps/engine[1]/helium-interconnect-valve-status == 1
			</test>
		</switch>

		<switch name="systems/mps/helium[2]/interconnect-in-valve-status">
			<default value="0.0"/>
			<test logic="AND" value="1.0">
				systems/mps/engine[2]/helium-interconnect-valve-status == 1
			</test>
		</switch>

		<switch name="systems/mps/helium[0]/interconnect-out-valve-status">
			<default value="0.0"/>
			<test logic="AND" value="1.0">
				systems/mps/engine[0]/helium-interconnect-valve-status == -1
			</test>
		</switch>

		<switch name="systems/mps/helium[1]/interconnect-out-valve-status">
			<default value="0.0"/>
			<test logic="AND" value="1.0">
				systems/mps/engine[1]/helium-interconnect-valve-status == -1
			</test>
		</switch>

		<switch name="systems/mps/helium[2]/interconnect-out-valve-status">
			<default value="0.0"/>
			<test logic="AND" value="1.0">
				systems/mps/engine[2]/helium-interconnect-valve-status == -1
			</test>
		</switch>

		<!-- pressure in the interconnect manifold is the highest connected pressure -->


		<fcs_function name="systems/mps/interconnect/pressure-fraction">
		<function>
			<max>
				<product>
					<property>propulsion/tank[28]/contents-lbs</property>
					<property>systems/mps/helium[0]/interconnect-out-valve-status</property>
				</product>
				<product>
					<property>propulsion/tank[29]/contents-lbs</property>
					<property>systems/mps/helium[1]/interconnect-out-valve-status</property>
				</product>
				<product>
					<property>propulsion/tank[30]/contents-lbs</property>
					<property>systems/mps/helium[2]/interconnect-out-valve-status</property>
				</product>
				<property>propulsion/tank[31]/contents-lbs</property>
			</max>
		</function>
		</fcs_function>


		<!-- reservoir can only supply to interconnect if it has interconnect manifold pressure -->

		<switch name="systems/mps/helium[0]/supply-status">
			<default value="0.0"/>
			<test logic="AND" value="1.0">
				systems/mps/helium[0]/interconnect-out-valve-status == 1
				propulsion/tank[28]/contents-lbs == systems/mps/interconnect/pressure-fraction
			</test>
		</switch>

		<switch name="systems/mps/helium[1]/supply-status">
			<default value="0.0"/>
			<test logic="AND" value="1.0">
				systems/mps/helium[1]/interconnect-out-valve-status == 1
				propulsion/tank[29]/contents-lbs == systems/mps/interconnect/pressure-fraction
			</test>
		</switch>

		<switch name="systems/mps/helium[2]/supply-status">
			<default value="0.0"/>
			<test logic="AND" value="1.0">
				systems/mps/helium[2]/interconnect-out-valve-status == 1
				propulsion/tank[30]/contents-lbs == systems/mps/interconnect/pressure-fraction
			</test>
		</switch>

		<switch name="systems/mps/helium[3]/supply-status">
			<default value="0.0"/>
			<test logic="AND" value="1.0">
				propulsion/tank[31]/contents-lbs == systems/mps/interconnect/pressure-fraction
			</test>
		</switch>

		<!-- engine can only draw from interconnect if its reservoir pressure is lower -->

		<switch name="systems/mps/helium[0]/demand-status">
			<default value="0.0"/>
			<test logic="AND" value="1.0">
				systems/mps/helium[0]/interconnect-in-valve-status == 1
				propulsion/tank[28]/contents-lbs LT systems/mps/interconnect/pressure-fraction
				systems/mps/engine/engine-running == 1
			</test>
			<test logic="AND" value="1.0">
				systems/mps/helium[0]/interconnect-in-valve-status == 1
				propulsion/tank[28]/contents-lbs LT systems/mps/interconnect/pressure-fraction
				systems/failures/leakage/mps-left-helium-leak-flow LT 0
			</test>
			<test logic="AND" value="1.0">
				systems/mps/helium[0]/interconnect-in-valve-status == 1
				propulsion/tank[28]/contents-lbs LT systems/mps/interconnect/pressure-fraction
				systems/failures/leakage/mps-inct-helium-leak-flow LT 0
			</test>
		</switch>

		<switch name="systems/mps/helium[1]/demand-status">
			<default value="0.0"/>
			<test logic="AND" value="1.0">
				systems/mps/helium[1]/interconnect-in-valve-status == 1
				propulsion/tank[29]/contents-lbs LT systems/mps/interconnect/pressure-fraction
				systems/mps/engine[1]/engine-running == 1
			</test>
			<test logic="AND" value="1.0">
				systems/mps/helium[1]/interconnect-in-valve-status == 1
				propulsion/tank[29]/contents-lbs LT systems/mps/interconnect/pressure-fraction
				systems/failures/leakage/mps-right-helium-leak-flow LT 0
			</test>
			<test logic="AND" value="1.0">
				systems/mps/helium[1]/interconnect-in-valve-status == 1
				propulsion/tank[29]/contents-lbs LT systems/mps/interconnect/pressure-fraction
				systems/failures/leakage/mps-inct-helium-leak-flow LT 0
			</test>
		</switch>

		<switch name="systems/mps/helium[2]/demand-status">
			<default value="0.0"/>
			<test logic="AND" value="1.0">
				systems/mps/helium[2]/interconnect-in-valve-status == 1
				propulsion/tank[30]/contents-lbs LT systems/mps/interconnect/pressure-fraction
				systems/mps/engine[2]/engine-running == 1
			</test>
			<test logic="AND" value="1.0">
				systems/mps/helium[2]/interconnect-in-valve-status == 1
				propulsion/tank[30]/contents-lbs LT systems/mps/interconnect/pressure-fraction
				systems/failures/leakage/mps-center-helium-leak-flow LT 0
			</test>
			<test logic="AND" value="1.0">
				systems/mps/helium[2]/interconnect-in-valve-status == 1
				propulsion/tank[30]/contents-lbs LT systems/mps/interconnect/pressure-fraction
				systems/failures/leakage/mps-inct-helium-leak-flow LT 0
			</test>
		</switch>

		<!-- count supply and demand -->

		<fcs_function name="systems/mps/interconnect/num-supply">
		<function>
			<sum>
				<property>systems/mps/helium[0]/supply-status</property>
				<property>systems/mps/helium[1]/supply-status</property>
				<property>systems/mps/helium[2]/supply-status</property>
				<property>systems/mps/helium[3]/supply-status</property>
			</sum>
		</function>
		</fcs_function>

		<fcs_function name="systems/mps/interconnect/num-demand">
		<function>
			<sum>
				<property>systems/mps/helium[0]/demand-status</property>
				<property>systems/mps/helium[1]/demand-status</property>
				<property>systems/mps/helium[2]/demand-status</property>
			</sum>
		</function>
		</fcs_function>

		<!-- drain rates via interconnect -->

		<fcs_function name="systems/mps/interconnect/interconnect-drain-pps">
		<function>
			<quotient>
				<product>
					<sum>
					<value>-0.001</value>
					<property>systems/failures/leakage/mps-inct-helium-leak-flow</property>
					</sum>
					<property>systems/mps/interconnect/num-demand</property>
				</product>
				<property>systems/mps/interconnect/num-supply</property>
			</quotient>
		</function>
		</fcs_function>


		<!-- combined drain rates  -->

		<fcs_function name="systems/mps/helium/drain-rate-pps">
		<function>
			<sum>
			<product>
				<difference>
					<value>1.0</value>
					<property>systems/mps/helium[0]/demand-status</property>
				</difference>
				<property>systems/mps/engine/engine-running</property>
				<value>-0.000714</value>
			</product>
			<product>
				<property>systems/mps/helium[0]/supply-status</property>
				<property>systems/mps/interconnect/interconnect-drain-pps</property>
			</product>
			<property>systems/failures/leakage/mps-left-helium-leak-flow</property>
			</sum>
		</function>
		<output>propulsion/tank[28]/external-flow-rate-pps</output>
		</fcs_function>	

		<fcs_function name="systems/mps/helium[1]/drain-rate-pps">
		<function>
			<sum>
			<product>
				<difference>
					<value>1.0</value>
					<property>systems/mps/helium[1]/demand-status</property>
				</difference>
				<property>systems/mps/engine[1]/engine-running</property>
				<value>-0.000714</value>
			</product>
			<product>
				<property>systems/mps/helium[1]/supply-status</property>
				<property>systems/mps/interconnect/interconnect-drain-pps</property>
			</product>
			<property>systems/failures/leakage/mps-right-helium-leak-flow</property>
			</sum>
		</function>
		<output>propulsion/tank[29]/external-flow-rate-pps</output>
		</fcs_function>	

		<fcs_function name="systems/mps/helium[2]/drain-rate-pps">
		<function>
			<sum>
			<product>
				<difference>
					<value>1.0</value>
					<property>systems/mps/helium[2]/demand-status</property>
				</difference>
				<property>systems/mps/engine[2]/engine-running</property>
				<value>-0.000714</value>
			</product>
			<product>
				<property>systems/mps/helium[2]/supply-status</property>
				<property>systems/mps/interconnect/interconnect-drain-pps</property>
			</product>
			<property>systems/failures/leakage/mps-center-helium-leak-flow</property>
			</sum>
		</function>
		<output>propulsion/tank[30]/external-flow-rate-pps</output>
		</fcs_function>		

		<fcs_function name="systems/mps/helium[3]/drain-rate-pps">
		<function>
			<sum>
			<product>
				<property>systems/mps/mps-running</property>
				<value>-0.00001</value>
			</product>
			<product>
				<property>systems/mps/helium[3]/supply-status</property>
				<property>systems/mps/interconnect/interconnect-drain-pps</property>
			</product>
			<property>systems/failures/leakage/mps-pneu-helium-leak-flow</property>
			</sum>
		</function>
		<output>propulsion/tank[31]/external-flow-rate-pps</output>
		</fcs_function>	





	</channel>


	<channel name="Helium pressure values to display">

		<!-- reservoir pressures -->

		<fcs_function name="systems/mps/helium/pressure-psia">
		<function>
			<product>
				<value>4700.0</value>
				<property>propulsion/tank[28]/contents-lbs</property>
			</product>
		</function>
		</fcs_function>

		<fcs_function name="systems/mps/helium[1]/pressure-psia">
		<function>
			<product>
				<value>4700.0</value>
				<property>propulsion/tank[29]/contents-lbs</property>
			</product>
		</function>
		</fcs_function>

		<fcs_function name="systems/mps/helium[2]/pressure-psia">
		<function>
			<product>
				<value>4700.0</value>
				<property>propulsion/tank[30]/contents-lbs</property>
			</product>
		</function>
		</fcs_function>

		<fcs_function name="systems/mps/helium[3]/pressure-psia">
		<function>
			<product>
				<value>4700.0</value>
				<property>propulsion/tank[31]/contents-lbs</property>
			</product>
		</function>
		</fcs_function>

		<fcs_function name="systems/mps/interconnect/pressure-psia">
		<function>
			<product>
				<property>systems/mps/interconnect/pressure-fraction</property>
				<value>4700.0</value>
			</product>
		</function>
		</fcs_function>


		<!-- isolation valve checks -->

		<switch name="systems/mps/helium/pressurized">
			<default value="0.0"/>
			<test logic="OR" value="1.0">
				systems/mps/engine/helium-isolation-valve-A-status == 1
				systems/mps/engine/helium-isolation-valve-B-status == 1
			</test>
		</switch>

		<switch name="systems/mps/helium[1]/pressurized">
			<default value="0.0"/>
			<test logic="OR" value="1.0">
				systems/mps/engine[1]/helium-isolation-valve-A-status == 1
				systems/mps/engine[1]/helium-isolation-valve-B-status == 1
			</test>
		</switch>

		<switch name="systems/mps/helium[2]/pressurized">
			<default value="0.0"/>
			<test logic="OR" value="1.0">
				systems/mps/engine[2]/helium-isolation-valve-A-status == 1
				systems/mps/engine[2]/helium-isolation-valve-B-status == 1
			</test>
		</switch>

		<switch name="systems/mps/helium[3]/pressurized">
			<default value="0.0"/>
			<test value="1.0">
				systems/mps/helium-isolation-valve-P-status == 1
			</test>
		</switch>

		<!-- regulator sees interconnect manifold pressure when interconnect valve takes in -->


		<fcs_function name="systems/mps/helium/pressure-manifold-psia">
		<function>
			<max>
				<property>systems/mps/helium/pressure-psia</property>
				<product>
					<property>systems/mps/helium[0]/interconnect-in-valve-status</property>
					<property>systems/mps/interconnect/pressure-psia</property>
				</product>
			</max>
		</function>
		</fcs_function>

		<fcs_function name="systems/mps/helium[1]/pressure-manifold-psia">
		<function>
			<max>
				<property>systems/mps/helium[1]/pressure-psia</property>
				<product>
					<property>systems/mps/helium[1]/interconnect-in-valve-status</property>
					<property>systems/mps/interconnect/pressure-psia</property>
				</product>
			</max>
		</function>
		</fcs_function>

		<fcs_function name="systems/mps/helium[2]/pressure-manifold-psia">
		<function>
			<max>
				<property>systems/mps/helium[2]/pressure-psia</property>
				<product>
					<property>systems/mps/helium[2]/interconnect-in-valve-status</property>
					<property>systems/mps/interconnect/pressure-psia</property>
				</product>
			</max>
		</function>
		</fcs_function>

		<!-- regulator pressures -->

		<fcs_function name="systems/mps/helium/reg-pressure-psia">
		<function>
			<product>
				<min>
					<property>systems/mps/helium/pressure-manifold-psia</property>
					<value>751.0</value>
				</min>
				<property>systems/mps/helium/pressurized</property>
			</product>
		</function>
		</fcs_function>

		<fcs_function name="systems/mps/helium[1]/reg-pressure-psia">
		<function>
			<product>
				<min>
					<property>systems/mps/helium[1]/pressure-manifold-psia</property>
					<value>751.0</value>
				</min>
				<property>systems/mps/helium[1]/pressurized</property>
			</product>
		</function>
		</fcs_function>

		<fcs_function name="systems/mps/helium[2]/reg-pressure-psia">
		<function>
			<product>
				<min>
					<property>systems/mps/helium[2]/pressure-manifold-psia</property>
					<value>751.0</value>
				</min>
				<property>systems/mps/helium[2]/pressurized</property>
			</product>
		</function>
		</fcs_function>

		<fcs_function name="systems/mps/helium[3]/reg-pressure-psia">
		<function>
			<product>
				<min>
					<property>systems/mps/interconnect/pressure-psia</property>
					<value>738.0</value>
				</min>
				<property>systems/mps/helium[3]/pressurized</property>
			</product>
		</function>
		</fcs_function>

		<switch name="systems/mps/helium-system-pressurized">
			<default value="0.0"/>
			<test logic="OR" value="1.0">
				systems/mps/helium/pressurized == 1
				systems/mps/helium[1]/pressurized == 1
				systems/mps/helium[2]/pressurized == 1
			</test>
		</switch>



	</channel>

	<channel name="Main propulsion system control">

		<!-- the engine controllers draw power from different buses so that any -->
		<!-- one failure leaves full control and any two failures leave two engines -->

		<switch name="systems/mps/engine/controller-A-power">
			<default value="0.0"/>
			<test logic="AND" value="1.0">
				systems/electrical/ac[1]/power-available == 1
				systems/mps/engine/controller-A-power-switch-status == 1
			</test>
		</switch>

		<switch name="systems/mps/engine/controller-B-power">
			<default value="0.0"/>
			<test logic="AND" value="1.0">
				systems/electrical/ac[2]/power-available == 1
				systems/mps/engine/controller-B-power-switch-status == 1
			</test>
		</switch>

		<switch name="systems/mps/engine[1]/controller-A-power">
			<default value="0.0"/>
			<test logic="AND" value="1.0">
				systems/electrical/ac[2]/power-available == 1
				systems/mps/engine[1]/controller-A-power-switch-status == 1
			</test>
		</switch>

		<switch name="systems/mps/engine[1]/controller-B-power">
			<default value="0.0"/>
			<test logic="AND" value="1.0">
				systems/electrical/ac/power-available == 1
				systems/mps/engine[1]/controller-B-power-switch-status == 1
			</test>
		</switch>

		<switch name="systems/mps/engine[2]/controller-A-power">
			<default value="0.0"/>
			<test logic="AND" value="1.0">
				systems/electrical/ac/power-available == 1
				systems/mps/engine[2]/controller-A-power-switch-status == 1
			</test>
		</switch>

		<switch name="systems/mps/engine[2]/controller-B-power">
			<default value="0.0"/>
			<test logic="AND" value="1.0">
				systems/electrical/ac[1]/power-available == 1
				systems/mps/engine[2]/controller-B-power-switch-status == 1
			</test>
		</switch>

		<switch name="systems/mps/engine/controller-A-power-demand-kW">
		<default value="0.0"/>
			<test logic="AND" value="0.5">
				systems/mps/engine/controller-A-power == 1
			</test>
		</switch>

		<switch name="systems/mps/engine/controller-B-power-demand-kW">
		<default value="0.0"/>
			<test logic="AND" value="0.5">
				systems/mps/engine/controller-B-power == 1
			</test>
		</switch>

		<switch name="systems/mps/engine[1]/controller-A-power-demand-kW">
		<default value="0.0"/>
			<test logic="AND" value="0.5">
				systems/mps/engine[1]/controller-A-power == 1
			</test>
		</switch>

		<switch name="systems/mps/engine[1]/controller-B-power-demand-kW">
		<default value="0.0"/>
			<test logic="AND" value="0.5">
				systems/mps/engine[1]/controller-B-power == 1
			</test>
		</switch>

		<switch name="systems/mps/engine[2]/controller-A-power-demand-kW">
		<default value="0.0"/>
			<test logic="AND" value="0.5">
				systems/mps/engine[2]/controller-A-power == 1
			</test>
		</switch>

		<switch name="systems/mps/engine[2]/controller-B-power-demand-kW">
		<default value="0.0"/>
			<test logic="AND" value="0.5">
				systems/mps/engine[2]/controller-B-power == 1
			</test>
		</switch>


		<switch name="systems/mps/engine/controller-power">
			<default value="0.0"/>
			<test logic="OR" value="1.0">
				systems/mps/engine/controller-A-power == 1
				systems/mps/engine/controller-B-power == 1
			</test>
		</switch>

		<switch name="systems/mps/engine[1]/controller-power">
			<default value="0.0"/>
			<test logic="OR" value="1.0">
				systems/mps/engine[1]/controller-A-power == 1
				systems/mps/engine[1]/controller-B-power == 1
			</test>
		</switch>

		<switch name="systems/mps/engine[2]/controller-power">
			<default value="0.0"/>
			<test logic="OR" value="1.0">
				systems/mps/engine[2]/controller-A-power == 1
				systems/mps/engine[2]/controller-B-power == 1
			</test>
		</switch>

		<fcs_function name="systems/mps/engine/engine-operational">
		<function>
			<product>
				<property>systems/mps/engine/controller-power</property>
				<property>systems/failures/mps/ssme1-condition</property>
				<property>systems/mps/engine/run-cmd</property>
				<property>systems/propellant/LO2-left-prevalve-status</property>
				<property>systems/propellant/LH2-left-prevalve-status</property>
				<property>systems/propellant/propellant-available</property>
			</product>
		</function>
		</fcs_function>

	  	<fcs_function name="systems/mps/engine[1]/engine-operational">
		<function>
			<product>
				<property>systems/mps/engine[1]/controller-power</property>
				<property>systems/failures/mps/ssme2-condition</property>
				<property>systems/mps/engine[1]/run-cmd</property>
				<property>systems/propellant/LO2-right-prevalve-status</property>
				<property>systems/propellant/LH2-right-prevalve-status</property>
				<property>systems/propellant/propellant-available</property>
			</product>
		</function>
		</fcs_function>

		<fcs_function name="systems/mps/engine[2]/engine-operational">
		<function>
			<product>
				<property>systems/mps/engine[2]/controller-power</property>
				<property>systems/failures/mps/ssme3-condition</property>
				<property>systems/mps/engine[2]/run-cmd</property>
				<property>systems/propellant/LO2-center-prevalve-status</property>
				<property>systems/propellant/LH2-center-prevalve-status</property>
				<property>systems/propellant/propellant-available</property>
			</product>
		</function>
		</fcs_function>

		<summer name="systems/mps/number-engines-operational">
			<input>systems/mps/engine/engine-operational</input>
			<input>systems/mps/engine[1]/engine-operational</input>
			<input>systems/mps/engine[2]/engine-operational</input>
		</summer>


		<!-- if a redline condition exists, the engine runs unsafely -->
		<!-- we can only simulate low He pressure explicitly, the turbine discharge temperatures -->
		<!-- and Pc we can not, so they're just a common redline parameter -->

		<switch name="systems/mps/engine/engine-running-redline">
			<default value="0.0"/>
			<test logic="AND" value="1.0">
				systems/mps/engine/engine-operational == 1.0
				systems/mps/engine/redline == 1.0
			</test>
			<test logic="AND" value="1.0">
				systems/mps/engine/engine-operational == 1.0
				systems/mps/helium/reg-pressure-psia LT 680.0
			</test>
		</switch>

		<switch name="systems/mps/engine[1]/engine-running-redline">
			<default value="0.0"/>
			<test logic="AND" value="1.0">
				systems/mps/engine[1]/engine-operational == 1.0
				systems/mps/engine[1]/redline == 1.0
			</test>
			<test logic="AND" value="1.0">
				systems/mps/engine[1]/engine-operational == 1.0
				systems/mps/helium[1]/reg-pressure-psia LT 680.0
			</test>
		</switch>

		<switch name="systems/mps/engine[2]/engine-running-redline">
			<default value="0.0"/>
			<test logic="AND" value="1.0">
				systems/mps/engine[2]/engine-operational == 1.0
				systems/mps/engine[2]/redline == 1.0
			</test>
			<test logic="AND" value="1.0">
				systems/mps/engine[2]/engine-operational == 1.0
				systems/mps/helium[2]/reg-pressure-psia LT 680.0
			</test>
		</switch>
		

		<!-- each engine needs the hydraulics system to actuate valves, otherwise it is in lockup -->
		<!-- SYS 1 actuates center engine, SYS 2 left engine and SYS 3 right engine -->
		<!-- alternatively it can end up in electrical lockup -->

		<switch name="systems/mps/engine/hydraulic-power">
			<default value="0.0"/>
			<test logic="AND" value="1.0">
				systems/apu/hyd-2-pressurized == 1
				systems/apu/apu[1]/tvc-isolation-valve-status == 1
			</test>
		</switch>


		<switch name="systems/mps/engine/lockup">
			<default value="0.0"/>
			<test logic="OR" value="1.0">
				systems/mps/engine/hydraulic-power == 0
				systems/mps/engine/electric-lockup == 1
			</test>
		</switch>


		<switch name="systems/mps/engine[1]/hydraulic-power">
			<default value="0.0"/>
			<test logic="AND" value="1.0">
				systems/apu/hyd-3-pressurized == 1
				systems/apu/apu[2]/tvc-isolation-valve-status == 1
			</test>
		</switch>


		<switch name="systems/mps/engine[1]/lockup">
			<default value="0.0"/>
			<test logic="OR" value="1.0">
				systems/mps/engine[1]/hydraulic-power == 0
				systems/mps/engine[1]/electric-lockup == 1
			</test>
		</switch>

		<switch name="systems/mps/engine[2]/hydraulic-power">
			<default value="0.0"/>
			<test logic="AND" value="1.0">
				systems/apu/hyd-1-pressurized == 1
				systems/apu/apu/tvc-isolation-valve-status == 1
			</test>
		</switch>


		<switch name="systems/mps/engine[2]/lockup">
			<default value="0.0"/>
			<test logic="OR" value="1.0">
				systems/mps/engine[2]/hydraulic-power == 0
				systems/mps/engine[2]/electric-lockup == 1
			</test>
		</switch>

		<!-- gimbal control has extra redundancy with two systems gimbaling each engine -->
		<!-- center engine uses SYS 1 and SYS 3 -->
		<!-- left   engine uses SYS 1 and SYS 2 -->
		<!-- right  engine uses SYS 2 and SYS 3 -->


		<switch name="systems/mps/engine/gimbal-control">
			<default value="0.0"/>
			<test logic="OR" value="1.0">
				systems/mps/engine/hydraulic-power == 1
				systems/mps/engine[2]/hydraulic-power == 1
			</test>
		</switch>

		<switch name="systems/mps/engine[1]/gimbal-control">
			<default value="0.0"/>
			<test logic="OR" value="1.0">
				systems/mps/engine/hydraulic-power == 1
				systems/mps/engine[1]/hydraulic-power == 1
			</test>
		</switch>

		<switch name="systems/mps/engine[2]/gimbal-control">
			<default value="0.0"/>
			<test logic="OR" value="1.0">
				systems/mps/engine[2]/hydraulic-power == 1
				systems/mps/engine[1]/hydraulic-power == 1
			</test>
		</switch>

	</channel>



	<channel name="Main propulsion tanks vent if valves open">

		<switch name="systems/propellant/LO2-drain-open">
			<default value="0.0"/>
			<test logic="AND" value="1.0">
				systems/propellant/LO2-inboard-status == 1
				systems/propellant/LO2-outboard-status == 1
			</test>
		</switch>

		<switch name="systems/propellant/LH2-drain-open">
			<default value="0.0"/>
			<test logic="AND" value="1.0">
				systems/propellant/LH2-inboard-status == 1
				systems/propellant/LH2-outboard-status == 1
			</test>
		</switch>

		<fcs_function name="systems/propellant/LO2-drain-rate">
		<function>
			<product>
				<property>systems/propellant/LO2-drain-open</property>
				<value>-50.0</value>
			</product>
		</function>
		</fcs_function>

		<fcs_function name="systems/propellant/LH2-drain-rate">
		<function>
			<product>
				<property>systems/propellant/LH2-drain-open</property>
				<value>-50.0</value>
			</product>
		</function>
		</fcs_function>

		<fcs_function name="systems/propellant/total-ET-drain-rate">
		<function>
			<sum>
				<property>systems/propellant/LO2-drain-rate</property>
				<property>systems/propellant/LH2-drain-rate</property>
			</sum>
		</function>
		<output>propulsion/tank/external-flow-rate-pps</output>
		</fcs_function>
	</channel>


	<channel name="Engine manifold pressures" execrate="4">

		<fcs_function name="systems/mps/lo2-manifold-pressure-psia">
		<function>
			<sum>
			<product>
				<property>/sim/config/shuttle/prelaunch-flag</property>
				<value>21.0</value>
			</product>
			<product>
				<value>23.5</value>
				<max>
					<property>systems/mps/engine/engine-operational</property>
					<property>systems/mps/engine[1]/engine-operational</property>
					<property>systems/mps/engine[2]/engine-operational</property>
				</max>
			</product>
			<product>
				<property>systems/mps/helium/et-fuel-fraction</property>
				<property>accelerations/a-pilot-ft_sec2</property>
				<value>0.03108095</value>
				<value>80.0</value>
			</product>
			<product>
				<property>systems/mps/propellant-dump-cmd</property>
				<value>24.0</value>
			</product>
			</sum>
		</function>
		</fcs_function>

		<fcs_function name="systems/mps/lh2-manifold-pressure-psia">
		<function>
			<sum>
			<product>
				<property>/sim/config/shuttle/prelaunch-flag</property>
				<value>42.0</value>
			</product>
			<product>
				<value>32.8</value>
				<max>
					<property>systems/mps/engine/engine-operational</property>
					<property>systems/mps/engine[1]/engine-operational</property>
					<property>systems/mps/engine[2]/engine-operational</property>
				</max>
			</product>
			<product>
				<property>systems/mps/helium/et-fuel-fraction</property>
				<property>accelerations/a-pilot-ft_sec2</property>
				<value>0.03108095</value>
				<value>4.9</value>
			</product>
			<product>
				<property>systems/mps/propellant-dump-cmd</property>
				<value>24.0</value>
			</product>
			</sum>
		</function>
		</fcs_function>

	</channel>
</system>
