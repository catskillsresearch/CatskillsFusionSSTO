<?xml version="1.0" encoding="utf-8"?>
<!-- Bump and specular effect -->
<PropertyList>
  <name>Aircraft/CatskillsFusionSSTO/Models/HST/foil-normal</name>
  <inherits-from>Aircraft/CatskillsFusionSSTO/HST/hst-shine</inherits-from>
  <parameters>
    <texture n="2">
      <image>Aircraft/CatskillsFusionSSTO/Models/HST/foil-normal.png</image>
      <filter>linear-mipmap-linear</filter>
      <wrap-s>repeat</wrap-s>
      <wrap-t>repeat</wrap-t>
      <internal-format>normalized</internal-format>
    </texture>
  </parameters>
</PropertyList>
