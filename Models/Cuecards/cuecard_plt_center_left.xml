<?xml version="1.0"?>

<PropertyList>

    	<path>Aircraft/CatskillsFusionSSTO/Models/Cuecards/cuecard_plt_center_left.ac</path>


   	<effect>
         <inherits-from>Aircraft/CatskillsFusionSSTO/Models/Effects/shuttle-cuecard-object</inherits-from>
	 <object-name>Cuecard-PLT-center-left</object-name>
    	</effect>


	 <animation>
	  <type>pick</type>
	   <object-name>Cuecard-PLT-center-left</object-name>
	   <action>
	    <button>0</button>
	    <repeatable>false</repeatable>
	    <interval-sec>0.2</interval-sec>
	    <binding>
	     <command>nasal</command>
                <script>SpaceShuttle.cue_card_binder_PLT.popup_left_page();</script>
	    </binding>
	   </action>
	   <action>
	    <button>3</button>
	    <repeatable>false</repeatable>
	    <interval-sec>0.2</interval-sec>
	    <binding>
	     <command>nasal</command>
                <script>SpaceShuttle.cue_card_binder_PLT.next_page(1);</script>
	    </binding>
	   </action>
	   <action>
	    <button>4</button>
	    <repeatable>false</repeatable>
	    <interval-sec>0.2</interval-sec>
	    <binding>
	     <command>nasal</command>
                <script>SpaceShuttle.cue_card_binder_PLT.next_page(-1);</script>
	    </binding>
	   </action>
	 </animation>

</PropertyList>
