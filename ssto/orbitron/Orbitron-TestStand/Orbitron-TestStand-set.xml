<?xml version="1.0"?>
<PropertyList>
    <sim>
        <description>Orbitron p-B11 Test Stand</description>
        <author>Catskills Aerospace</author>
        <status>alpha</status>
        
        <!-- Fixes the Version Warning -->
        <minimum-fg-version>2020.3.0</minimum-fg-version>
        
        <flight-model>jsb</flight-model>
        <aero>orbitron-jsbsim</aero>

        <!-- Pure relative paths for custom desktop directories -->
        <model>
            <path>Models/Orbitron.xml</path>
            <!-- Moved trigger here so it becomes /sim/model/reactor/startup-trigger -->
            <reactor>
                <startup-trigger type="bool">false</startup-trigger>
                <debug-ui-window type="bool">false</debug-ui-window>
            </reactor>
        </model>

	<sound>
            <path>Sounds/sound.xml</path>
            <!-- KILL AI & RADIO CHATTER -->
            <chatter-volume type="double">0.0</chatter-volume>
            <atc-volume type="double">0.0</atc-volume>
            <avionics-volume type="double">0.0</avionics-volume>
        </sound>

	<view n="0">
            <name>Operator View</name>
            <type>lookfrom</type>
            <internal>true</internal>
            <config>
                <x-offset-m archive="n"> 0.0 </x-offset-m>
                <y-offset-m archive="n"> 2.0 </y-offset-m>
                <z-offset-m archive="n"> 12.0 </z-offset-m>
                <pitch-offset-deg archive="n"> -8.0 </pitch-offset-deg>
            </config>
        </view>

    </sim>

    <!-- ======================================================== -->
    <!-- MUST BE OUTSIDE THE <sim> TAG SO JSBSIM CAN FIND IT!     -->
    <!-- ======================================================== -->
    <controls>
        <reactor>
            <throttle type="double">0.0</throttle>
        </reactor>
    </controls>

    <!-- CUSTOM KEYBOARD CONTROLS (Must be outside <sim>) -->
    <input>
        <keyboard>
            <!-- SPACEBAR (Key 32) : Toggle Reactor Ignition -->
            <key n="32">
                <name>SPACE</name>
                <desc>Toggle Reactor Ignition</desc>
                <binding>
                    <command>property-toggle</command>
                    <property>/sim/model/reactor/startup-trigger</property>
                </binding>
            </key>

            <!-- W Key (Key 119) : Throttle UP -->
            <key n="119">
                <name>w</name>
                <desc>Increase NBI Injection</desc>
                <binding>
                    <command>property-adjust</command>
                    <property>/controls/reactor/throttle</property>
                    <step>0.1</step>
                    <min>0.0</min>
                    <max>1.0</max>
                </binding>
            </key>

            <!-- S Key (Key 115) : Throttle DOWN -->
            <key n="115">
                <name>s</name>
                <desc>Decrease NBI Injection</desc>
                <binding>
                    <command>property-adjust</command>
                    <property>/controls/reactor/throttle</property>
                    <step>-0.1</step>
                    <min>0.0</min>
                    <max>1.0</max>
                </binding>
            </key>

            <!-- M Key (Key 109) : Toggle debug telemetry popup -->
            <key n="109">
                <name>m</name>
                <desc>Toggle Reactor Telemetry Debug Window</desc>
                <binding>
                    <command>property-toggle</command>
                    <property>/sim/model/reactor/debug-ui-window</property>
                </binding>
            </key>
        </keyboard>
    </input>

    <nasal>
        <reactor_ui>
            <!-- Pure relative path -->
            <file>Nasal/reactor_ui.nas</file>
        </reactor_ui>
    </nasal>
</PropertyList>
