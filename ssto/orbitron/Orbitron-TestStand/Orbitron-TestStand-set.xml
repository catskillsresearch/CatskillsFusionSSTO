<?xml version="1.0"?>
<PropertyList>
    <sim>
        <description>Orbitron p-B11 Test Stand</description>
        <author>Catskills Aerospace</author>
        <status>alpha</status>
        
        <!-- Fixes the Version Warning -->
        <minimum-fg-version>2020.3.0</minimum-fg-version>
        
        <flight-model>jsb</flight-model>
        <aero>orbitron-jsbsim</aero>

        <!-- Pure relative paths for custom desktop directories -->
        <model>
            <path>Models/Orbitron.xml</path>
            <!-- Moved trigger here so it becomes /sim/model/reactor/startup-trigger -->
            <reactor>
                <startup-trigger type="bool">false</startup-trigger>
                <debug-ui-window type="bool">false</debug-ui-window>
                <!-- Set true briefly to fire reactor_audio_heavy.wav (optional one-shot). -->
                <startup-commissioning-audio type="bool">false</startup-commissioning-audio>
            </reactor>
            <!-- Bilinear coefficients read by orbitron-jsbsim.xml; Nasal may overwrite from engine_surrogate.json -->
            <orbitron>
                <surrogate>
                    <thrust-c0 type="double">0</thrust-c0>
                    <thrust-ct type="double">0</thrust-ct>
                    <thrust-cc type="double">0</thrust-cc>
                    <thrust-ctc type="double">4000</thrust-ctc>
                    <mdot-c0 type="double">0</mdot-c0>
                    <mdot-ct type="double">0</mdot-ct>
                    <mdot-cc type="double">0</mdot-cc>
                    <mdot-ctc type="double">2.5</mdot-ctc>
                    <power-c0 type="double">0</power-c0>
                    <power-ct type="double">0</power-ct>
                    <power-cc type="double">0</power-cc>
                    <power-ctc type="double">3.5</power-ctc>
                    <heat-c0 type="double">0</heat-c0>
                    <heat-ct type="double">0</heat-ct>
                    <heat-cc type="double">0</heat-cc>
                    <heat-ctc type="double">400</heat-ctc>
                    <beam-screen-kw-c0 type="double">0</beam-screen-kw-c0>
                    <beam-screen-kw-ct type="double">55</beam-screen-kw-ct>
                    <beam-screen-kw-cc type="double">48</beam-screen-kw-cc>
                    <beam-screen-kw-ctc type="double">320</beam-screen-kw-ctc>
                </surrogate>
            </orbitron>
        </model>

	<sound>
            <path>Sounds/sound.xml</path>
            <!-- KILL AI & RADIO CHATTER -->
            <chatter-volume type="double">0.0</chatter-volume>
            <atc-volume type="double">0.0</atc-volume>
            <avionics-volume type="double">0.0</avionics-volume>
        </sound>

	<view n="0">
            <name>Operator View</name>
            <type>lookfrom</type>
            <internal>true</internal>
            <config>
                <x-offset-m archive="n"> 0.0 </x-offset-m>
                <y-offset-m archive="n"> 2.0 </y-offset-m> <!-- Operator eye-level height -->
                
                <z-offset-m archive="n"> 2.0 </z-offset-m> <!-- Stand exactly 2 meters (~6.5 ft) back from the console -->
                
                <pitch-offset-deg archive="n"> -8.0 </pitch-offset-deg> <!-- Angled down to look at the console -->
            </config>
        </view>

    </sim>

    <!-- ======================================================== -->
    <!-- MUST BE OUTSIDE THE <sim> TAG SO JSBSIM CAN FIND IT!     -->
    <!-- ======================================================== -->
    <controls>
        <reactor>
            <throttle type="double">0.0</throttle>
        </reactor>
        <orbitron>
            <compressor type="double">0.0</compressor>
        </orbitron>
    </controls>

    <!-- CUSTOM KEYBOARD CONTROLS (Must be outside <sim>) -->
    <input>
        <keyboard>
            <!-- SPACEBAR (Key 32) : Toggle Reactor Ignition -->
            <key n="32">
                <name>SPACE</name>
                <desc>Toggle Reactor Ignition</desc>
                <binding>
                    <command>property-toggle</command>
                    <property>/sim/model/reactor/startup-trigger</property>
                </binding>
            </key>

            <!-- W Key (Key 119) : Throttle UP -->
            <key n="119">
                <name>w</name>
                <desc>Increase NBI Injection</desc>
                <binding>
                    <command>property-adjust</command>
                    <property>/controls/reactor/throttle</property>
                    <step>0.1</step>
                    <min>0.0</min>
                    <max>1.0</max>
                </binding>
            </key>

            <!-- S Key (Key 115) : Throttle DOWN -->
            <key n="115">
                <name>s</name>
                <desc>Decrease NBI Injection</desc>
                <binding>
                    <command>property-adjust</command>
                    <property>/controls/reactor/throttle</property>
                    <step>-0.1</step>
                    <min>0.0</min>
                    <max>1.0</max>
                </binding>
            </key>

            <!-- M Key (Key 109) : Toggle debug telemetry popup -->
            <key n="109">
                <name>m</name>
                <desc>Toggle Reactor Telemetry Debug Window</desc>
                <binding>
                    <command>property-toggle</command>
                    <property>/sim/model/reactor/debug-ui-window</property>
                </binding>
            </key>

            <!-- U / J : compressor vane / motor command (arcjet air path) -->
            <key n="117">
                <name>u</name>
                <desc>Increase compressor command</desc>
                <binding>
                    <command>property-adjust</command>
                    <property>/controls/orbitron/compressor</property>
                    <step>0.1</step>
                    <min>0.0</min>
                    <max>1.0</max>
                </binding>
            </key>
            <key n="106">
                <name>j</name>
                <desc>Decrease compressor command</desc>
                <binding>
                    <command>property-adjust</command>
                    <property>/controls/orbitron/compressor</property>
                    <step>-0.1</step>
                    <min>0.0</min>
                    <max>1.0</max>
                </binding>
            </key>
        </keyboard>
    </input>

    <nasal>
        <surrogate_load>
            <file>Nasal/surrogate_load.nas</file>
        </surrogate_load>
        <reactor_ui>
            <file>Nasal/reactor_ui.nas</file>
        </reactor_ui>
    </nasal>
</PropertyList>
