<?xml version="1.0" encoding="UTF-8"?>
<PropertyList>

    <sim>
        <description>Orbitron p-B11 3.5 MW Test Stand</description>
        <author>Catskills Aerospace</author>
        
        <flight-model>jsb</flight-model>
        <aero>Orbitron_TestStand</aero> <!-- Points to the JSBSim XML -->

        <!-- Start on the ground, stationary -->
        <presets>
            <speed-set>0</speed-set>
            <altitude-ft>10</altitude-ft>
            <pitch-deg>0</pitch-deg>
        </presets>

        <!-- Load the 3D Model -->
        <model>
            <path>Aircraft/Orbitron_TestStand/Models/single_tube_stand.ac</path>
        </model>

        <!-- Tell FlightGear to show these specific reactor properties in the on-screen UI -->
        <hud>
            <enable3d>false</enable3d>
        </hud>
        
    </sim>

    <!-- Expose Reactor telemetry to the property tree so gauges can read them -->
    <reactor>
        <injection-sccm type="double">0.0</injection-sccm>
        <alpha-power-mw type="double">0.0</alpha-power-mw>
        <xray-heat-kw type="double">0.0</xray-heat-kw>
        <coolant-flow-kgs type="double">0.0</coolant-flow-kgs>
        <wall-temp-c type="double">20.0</wall-temp-c>
    </reactor>

</PropertyList>
