<?xml version="1.0"?>
<PropertyList>
    <path>orbitron.ac</path>

    <!-- 3D MODEL ORIENTATION ALIGNMENT -->
    <offsets>
        <!-- We reset Pitch, and use Roll to cartwheel it upright -->
        <pitch-deg> 0 </pitch-deg> 
        <roll-deg> -90 </roll-deg> 
        <heading-deg> 0 </heading-deg>
        
        <!-- Let's put this back to 0.0 so the tanks aren't floating -->
        <z-m> -1.0 </z-m> 
    </offsets>

    <!-- CLICKABLE STARTUP TRIGGER -->
    <!-- Temporarily mapped to the Operator_Console until the Button is exported -->
    <animation>
        <type>pick</type>
        <object-name>Operator_Console</object-name>
        <action>
            <button>0</button>
            <repeatable>false</repeatable>
            <binding>
                <command>property-assign</command>
                <property>/sim/model/reactor/startup-trigger</property>
                <value>1</value>
            </binding>
        </action>
    </animation>

    <!-- THROTTLE ANIMATION DISABLED 
    <animation>
        <type>translate</type>
        <object-name>Throttle_Slider</object-name>
        <property>/controls/engines/engine[0]/throttle</property>
        <factor>0.2</factor> 
        <axis>
            <x>-1</x> 
            <y>0</y>
            <z>0</z>
        </axis>
    </animation>
    -->
</PropertyList>
