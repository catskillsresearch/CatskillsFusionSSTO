<?xml version="1.0"?>
<PropertyList>
    <!-- Mesh orbitron.ac from orbitron_lab_v5.gltf: engine stack on sled deck, tanks/plumbing/console. Tune offsets below if the rig sits wrong on the runway. -->
    <path>orbitron.ac</path>

    <offsets>
        <pitch-deg> 0 </pitch-deg> 
        <roll-deg> 0 </roll-deg> 
        <heading-deg> 90 </heading-deg> <!-- Rotates the rig to point forward -->
        
        <y-m> 10.0 </y-m> <!-- Pulls the long nose of the 3D model 10 meters straight backward -->
        <z-m> -0.5 </z-m> 
    </offsets>

    <!-- ANIMATION 1: Armed Big Red Button -->
    <animation>
        <type>pick</type>
        <object-name>Big_Red_Button</object-name>
        <action>
            <button>0</button>
            <repeatable>false</repeatable>
            <binding>
                <command>property-toggle</command>
                <property>/sim/model/reactor/startup-trigger</property>
            </binding>
        </action>
    </animation>

</PropertyList>
