<?xml version="1.0"?>
<PropertyList>
    <path>orbitron.ac</path>

    <offsets>
        <pitch-deg> 0 </pitch-deg> 
        <roll-deg> 0 </roll-deg> 
        <heading-deg> 90 </heading-deg> <!-- Spun to face the camera -->
        <z-m> -0.5 </z-m> 
    </offsets>

    <!-- ANIMATION 1: Ambient light fix (Notice there is no <object-name>, so it applies to everything) -->
    <animation>
        <type>material</type>
        <emission>
            <red>0.15</red>
            <green>0.15</green>
            <blue>0.15</blue>
        </emission>
    </animation>

    <!-- ANIMATION 2: Armed Big Red Button -->
    <animation>
        <type>pick</type>
        <object-name>Big_Red_Button</object-name>
        <action>
            <button>0</button>
            <repeatable>false</repeatable>
            <binding>
                <command>property-toggle</command>
                <property>/sim/model/reactor/startup-trigger</property>
            </binding>
        </action>
    </animation>

</PropertyList>
