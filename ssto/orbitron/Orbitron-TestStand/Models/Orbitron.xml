<?xml version="1.0"?>
<PropertyList>
  <path>orbitron.ac</path>

      <!-- SPINS AND LIFTS THE ENTIRE 3D MODEL -->
    <offsets>
        <!-- Try 90, -90, or 180 to twist the console toward the camera -->
        <heading-deg> 90 </heading-deg> 
        <!-- Lift the model 1 meter up so it sits on top of the concrete -->
        <z-m> 1.0 </z-m> 
    </offsets>

    <!-- CLICKABLE STARTUP TRIGGER -->
    <!-- Temporarily mapped to the Operator_Console until the Button is exported -->
    <animation>
        <type>pick</type>
        <object-name>Operator_Console</object-name>
        <action>
            <button>0</button>
            <repeatable>false</repeatable>
            <binding>
                <command>property-assign</command>
                <property>/sim/model/reactor/startup-trigger</property>
                <value>1</value>
            </binding>
        </action>
    </animation>

    <!-- THROTTLE ANIMATION DISABLED 
    <animation>
        <type>translate</type>
        <object-name>Throttle_Slider</object-name>
        <property>/controls/engines/engine[0]/throttle</property>
        <factor>0.2</factor> 
        <axis>
            <x>-1</x> 
            <y>0</y>
            <z>0</z>
        </axis>
    </animation>
    -->
</PropertyList>
