import cadquery as cq

class IntegratedOrbitronTube:
    """The 3.5 MW p-B11 Reactor Core built on the Z-axis (Rotated later)"""
    def build(self):
        r = 0.05
        h = 2.0
        # Niobium Anode
        anode = cq.Workplane("XY").cylinder(h, r).faces(">Z").workplane().hole(r*2 - 0.01)
        # Molybdenum DEC Grid
        dec = cq.Workplane("XY").cylinder(h, r-0.005).faces(">Z").workplane().hole((r-0.005)*2 - 0.002)
        # Tungsten Cathode
        cathode = cq.Workplane("XY").cylinder(h + 0.6, 0.005)
        # HV Insulators
        ins = cq.Workplane("XY").cylinder(0.3, 0.03)
        for i in range(5):
            ins = ins.union(cq.Workplane("XY").workplane(offset=-0.1 + i*0.05).cylinder(0.02, 0.045))
        ins_top = ins.translate((0, 0, h/2 + 0.15))
        ins_bot = ins.translate((0, 0, -h/2 - 0.15))
        # YBCO Magnet
        mag = cq.Workplane("XY").cylinder(h-0.5, 0.15).faces(">Z").workplane().hole(r*2 + 0.01)
        # Neutral Beam Injector (Bolted to the side, pointing along local +Y)
        nbi = cq.Workplane("XZ").cylinder(0.2, 0.04).translate((0, 0.1, 0))
        nbi_flange = cq.Workplane("XZ").cylinder(0.05, 0.06).translate((0, 0.2, 0))
        
        return anode, dec, cathode, ins_top.union(ins_bot), mag, nbi.union(nbi_flange)

class LabInfrastructure:
    """The Test Facility (Anchored explicitly to Z=0)"""
    
    def build_table(self):
        # Legs: Base at Z=0, Height=1.0 -> Center at Z=0.5
        legs = (cq.Workplane("XY").box(0.1, 0.1, 1.0).translate((0.6, 0.3, 0.5))
                .union(cq.Workplane("XY").box(0.1, 0.1, 1.0).translate((-0.6, 0.3, 0.5)))
                .union(cq.Workplane("XY").box(0.1, 0.1, 1.0).translate((0.6, -0.3, 0.5)))
                .union(cq.Workplane("XY").box(0.1, 0.1, 1.0).translate((-0.6, -0.3, 0.5))))
        # Tabletop: Z=1.0
        top = cq.Workplane("XY").box(1.5, 0.8, 0.05).translate((0, 0, 1.0))
        # V-Mounts: Z=1.0 to 1.25 -> Center at Z=1.125
        mounts = (cq.Workplane("XY").box(0.1, 0.2, 0.25).translate((0.5, 0, 1.125))
                  .union(cq.Workplane("XY").box(0.1, 0.2, 0.25).translate((-0.5, 0, 1.125))))
        # 3D Placard
        label = cq.Workplane("XY").workplane(offset=1.025).text("ORBITRON p-B11 FUSION", 0.08, 0.01).translate((0, -0.3, 0))
        return legs.union(top).union(mounts).union(label)

    def build_console(self):
        # Base cabinet: Z=0 to Z=1.2 -> Center at Z=0.6. Moved Left (Y=-1.2)
        base = cq.Workplane("XY").box(0.8, 0.6, 1.2).translate((0, -1.2, 0.6))
        # Angled Control Panel
        panel = cq.Workplane("XY").box(0.8, 0.5, 0.05).rotate((1,0,0), (0,0,0), 30).translate((0, -1.2, 1.3))
        # Telemetry Screen (Canvas for FlightGear)
        screen = cq.Workplane("XY").box(0.6, 0.3, 0.05).rotate((1,0,0), (0,0,0), 30).translate((0, -1.1, 1.45))
        # Big Red Button
        brb = cq.Workplane("XY").cylinder(0.04, 0.05).rotate((1,0,0),(0,0,0),30).translate((0.2, -1.25, 1.35))
        # Battery at the base
        batt = cq.Workplane("XY").box(0.7, 0.5, 0.4).translate((0, -1.2, 0.2))
        return base.union(panel).union(screen).union(brb).union(batt)

    def build_fuel_farm(self):
        # Tanks moved Right (Y=1.2). Extruded directly from Z=0.
        h2 = cq.Workplane("XY", origin=(0.5, 1.2, 0)).circle(0.15).extrude(1.2).edges(">Z").fillet(0.1)
        b2h6 = cq.Workplane("XY", origin=(0.0, 1.2, 0)).circle(0.15).extrude(1.2).edges(">Z").fillet(0.1)
        dewar = cq.Workplane("XY", origin=(-0.6, 1.2, 0)).circle(0.25).extrude(0.9).edges(">Z").fillet(0.1)
        
        # 3D Labels
        l1 = cq.Workplane("XZ", origin=(0.5, 1.05, 0.8)).text("H2", 0.1, 0.01)
        l2 = cq.Workplane("XZ", origin=(0.0, 1.05, 0.8)).text("B2H6", 0.08, 0.01)
        l3 = cq.Workplane("XZ", origin=(-0.6, 0.95, 0.6)).text("CH4", 0.1, 0.01)
        
        return h2.union(l1), b2h6.union(l2), dewar.union(l3)

    def build_cables(self):
        # 1. HV Cable (Console -> Magnet). Starts at Console Y=-1.1, Z=1.3
        hv_path = cq.Workplane("YZ").spline([(-1.1, 1.3), (-0.5, 1.6), (0.0, 1.4)])
        hv_cable = cq.Workplane("XZ").workplane(offset=-1.1).center(0, 1.3).circle(0.02).sweep(hv_path, isFrenet=True)

        # 2. Hydrogen Gas Line (Tank -> NBI). Starts at H2 Tank X=0.5, Y=1.2, Z=1.2
        h2_path = cq.Workplane("YZ").workplane(offset=0.5).spline([(1.2, 1.2), (0.6, 1.4), (0.2, 1.25)])
        gas1 = cq.Workplane("XZ").workplane(offset=1.2).center(0.5, 1.2).circle(0.015).sweep(h2_path, isFrenet=True)

        # 3. Diborane Gas Line (Tank -> NBI). Starts at B2H6 Tank X=0.0, Y=1.2, Z=1.2
        b2_path = cq.Workplane("YZ").spline([(1.2, 1.2), (0.6, 1.4), (0.2, 1.25)])
        gas2 = cq.Workplane("XZ").workplane(offset=1.2).center(0.0, 1.2).circle(0.015).sweep(b2_path, isFrenet=True)

        # 4. Liquid Methane Line (Dewar -> Anode). Starts at Dewar X=-0.6, Y=1.2, Z=0.9
        ch4_path = cq.Workplane("YZ").workplane(offset=-0.6).spline([(1.2, 0.9), (0.5, 0.9), (0.05, 1.25)])
        methane = cq.Workplane("XZ").workplane(offset=1.2).center(-0.6, 0.9).circle(0.025).sweep(ch4_path, isFrenet=True)
        
        return hv_cable, gas1.union(gas2), methane

# ==========================================
# ASSEMBLE AND EXPORT
# ==========================================
if __name__ == "__main__":
    print("Routing cables and finalizing 3D Layout...")
    tube = IntegratedOrbitronTube()
    infra = LabInfrastructure()
    assy = cq.Assembly(name="Orbitron_Test_Facility")

    # Colors
    c_niobium = cq.Color(0.8, 0.8, 0.85)   
    c_dec     = cq.Color(0.8, 0.6, 0.1)    
    c_cath    = cq.Color(0.2, 0.8, 0.9)    
    c_ceramic = cq.Color(0.9, 0.9, 0.9)    
    c_magnet  = cq.Color(0.2, 0.2, 0.2)    
    c_nbi     = cq.Color(0.3, 0.6, 0.4)    
    c_table   = cq.Color(0.15, 0.15, 0.15)    
    c_h2      = cq.Color(0.8, 0.1, 0.1)    
    c_b2h6    = cq.Color(0.1, 0.6, 0.2)    
    c_dewar   = cq.Color(0.7, 0.7, 0.8)    
    c_hv      = cq.Color(0.9, 0.4, 0.0)    
    c_brb     = cq.Color(0.9, 0.0, 0.0)

    # Add Lab Hardware
    assy.add(infra.build_table(), name="Optics_Table", color=c_table)
    assy.add(infra.build_console(), name="Operator_Console", color=c_table)
    h2, b2h6, dewar = infra.build_fuel_farm()
    assy.add(h2, name="Tank_Hydrogen", color=c_h2)
    assy.add(b2h6, name="Tank_Diborane", color=c_b2h6)
    assy.add(dewar, name="Tank_Cryo_Methane", color=c_dewar)
    
    # Add Cables
    hv, gas, meth = infra.build_cables()
    assy.add(hv, name="High_Voltage_Umbilical", color=c_hv)
    assy.add(gas, name="Fuel_Gas_Lines", color=cq.Color(0.1, 0.1, 0.1))
    assy.add(meth, name="Cryo_Methane_Piping", color=c_niobium)

    # Add Reactor (Rotated so it lies flat along the X axis at Z=1.25)
    anode, dec, cath, ins, mag, nbi = tube.build()
    r_assy = cq.Assembly(name="Reactor_Core")
    r_assy.add(anode, name="Anode", color=c_niobium)
    r_assy.add(dec, name="DEC_Grid", color=c_dec)
    r_assy.add(cath, name="Cathode", color=c_cath)
    r_assy.add(ins, name="Insulators", color=c_ceramic)
    r_assy.add(mag, name="Magnet", color=c_magnet)
    r_assy.add(nbi, name="NBI_Injector", color=c_nbi)
    
    # Rotate local Z to align with global X. Placed exactly at Z=1.25
    assy.add(r_assy, name="3_5MW_Tube", loc=cq.Location(cq.Vector(0, 0, 1.25), cq.Vector(0, 1, 0), 90))

    output_file = "orbitron_lab_v2.gltf"
    assy.save(output_file)
    print(f"Success! CAD saved to {output_file}")
